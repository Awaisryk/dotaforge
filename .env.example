# =============================================================================
# DOTAFORGE CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# Your Steam Account ID (32-bit)
# Find it on OpenDota - it's the number in the URL after /players/
# Example: https://www.opendota.com/players/101855970 -> 101855970
STEAM_ACCOUNT_ID=101855970

# Your display name (used for logging and future metadata)
PLAYER_NAME=Mr.Vesper

# ─────────────────────────────────────────────────────────────────────────────
# DOTA 2 PATH (Optional - will auto-detect if not set)
# ─────────────────────────────────────────────────────────────────────────────

# Path to your Dota 2 installation directory
# If not set, will auto-detect from Steam libraries
# Example: E:\Steam\steamapps\common\dota 2 beta
# DOTA2_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# OPENDOTA API (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Get an API key for higher rate limits (60 calls/min free without key)
# https://www.opendota.com/api-keys
# OPENDOTA_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# MATCH SELECTION
# ─────────────────────────────────────────────────────────────────────────────

# How many matches to record per day (1-10)
MATCH_SELECTION__MATCHES_PER_DAY=1

# Only record winning matches (true/false)
MATCH_SELECTION__ONLY_WINS=false

# Only record losing matches (true/false) - mutually exclusive with ONLY_WINS
MATCH_SELECTION__ONLY_LOSSES=false

# Filter by specific hero name (case-insensitive)
# Examples: "Invoker", "Pudge", "Anti-Mage"
# Leave empty to record any hero
MATCH_SELECTION__HERO_FILTER=

# Minimum match duration in seconds (default: 600 = 10 minutes)
MATCH_SELECTION__MIN_DURATION_SECONDS=600

# Maximum match duration in seconds (default: 5400 = 90 minutes)
MATCH_SELECTION__MAX_DURATION_SECONDS=5400

# Minimum KDA ratio to record (default: 0 = no minimum)
MATCH_SELECTION__MIN_KDA=0

# How to sort eligible matches: "date", "kda", or "duration"
MATCH_SELECTION__SORT_BY=date

# ─────────────────────────────────────────────────────────────────────────────
# RECORDING SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# Video resolution (WIDTHxHEIGHT)
# Options: 1920x1080, 1280x720, 2560x1440
RECORDING__RESOLUTION=1920x1080

# Video framerate
# Options: 30, 60, 120 (60 recommended)
RECORDING__FRAMERATE=60

# Quality preset
# Options: low, medium, high, lossless
RECORDING__QUALITY=high

# CRF (Constant Rate Factor) - lower is better quality, larger files
# Range: 0-51 (18 = high quality, 23 = balanced, 28 = smaller files)
RECORDING__CRF=18

# ─────────────────────────────────────────────────────────────────────────────
# STORAGE & CLEANUP
# ─────────────────────────────────────────────────────────────────────────────

# Automatically delete recorded videos after N days
STORAGE__AUTO_DELETE_DAYS=10

# Maximum storage to use for videos in GB
STORAGE__MAX_STORAGE_GB=100

# Delete replay .dem files after successful recording
STORAGE__CLEANUP_REPLAYS=true

# Delete temporary TGA frames after encoding
STORAGE__CLEANUP_TEMP=true

# ─────────────────────────────────────────────────────────────────────────────
# SCHEDULING
# ─────────────────────────────────────────────────────────────────────────────

# Time to run daily (24-hour format)
RUN_TIME=02:00

# Timezone (e.g., UTC, America/New_York, Europe/London)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=UTC

# ─────────────────────────────────────────────────────────────────────────────
# RETRY & TIMEOUTS
# ─────────────────────────────────────────────────────────────────────────────

# Maximum retries for failed operations
MAX_RETRIES=3

# Seconds to wait between retries
RETRY_DELAY_SECONDS=60

# Timeout for Dota 2 to load (seconds)
DOTA_LOAD_TIMEOUT=120

# ─────────────────────────────────────────────────────────────────────────────
# DEBUGGING
# ─────────────────────────────────────────────────────────────────────────────

# Enable verbose logging
DEBUG=false

# Dry run mode - don't actually launch Dota 2 (for testing)
DRY_RUN=false
